# Copy to .env.local and fill in your values

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — X (Twitter)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# OAuth — Instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Resend (email)
RESEND_API_KEY=

# Cloudflare Turnstile (login + register CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BLOB_BASE_URL=https://xxx.public.blob.vercel-storage.com
