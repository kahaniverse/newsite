# Copy to .env.local to run against the docker-compose dev stack.
# All values below match the services defined in ../docker-compose.yml.

# ── Postgres via local Neon HTTP proxy ────────────────────────────────────
# The hostname is "localhost"; the driver auto-routes through the proxy
# at NEON_LOCAL_PROXY_URL.
DATABASE_URL=postgres://postgres:postgres@localhost:55432/kahaniverse_dev?sslmode=disable
DATABASE_URL_UNPOOLED=postgres://postgres:postgres@localhost:55432/kahaniverse_dev?sslmode=disable
NEON_LOCAL_PROXY_URL=http://localhost:4455/sql

# ── Upstash Redis via local serverless-redis-http facade ──────────────────
UPSTASH_REDIS_REST_URL=http://localhost:18079
UPSTASH_REDIS_REST_TOKEN=local-dev-token

# ── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=dev-only-secret-replace-me-32chars-min

# ── OAuth providers (leave empty to disable; credentials login still works)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── Cloudflare Turnstile ─────────────────────────────────────────────────
# Leave empty in dev; verifyTurnstile() returns true when NODE_ENV !== production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Vercel Blob ───────────────────────────────────────────────────────────
# Leave empty in dev; the upload route falls back to writing under public/uploads/.
BLOB_READ_WRITE_TOKEN=

# ── Resend ────────────────────────────────────────────────────────────────
# Leave empty in dev; password-reset emails are printed to the server console.
RESEND_API_KEY=

# ── App URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BLOB_BASE_URL=http://localhost:3000/uploads
