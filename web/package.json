{
  "name": "kahaniverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":              "next dev",
    "build":            "next build",
    "start":            "next start",
    "lint":             "next lint",
    "typecheck":        "tsc --noEmit",
    "db:migrate":       "tsx scripts/migrate.ts",
    "db:seed":          "tsx scripts/seed.ts",
    "db:reset":         "tsx scripts/reset.ts",
    "generate:carousel":"tsx scripts/generate-carousel.ts",

    "stack:up":         "docker compose -f ../docker-compose.yml up -d",
    "stack:down":       "docker compose -f ../docker-compose.yml down",
    "stack:nuke":       "docker compose -f ../docker-compose.yml down -v",
    "stack:logs":       "docker compose -f ../docker-compose.yml logs -f",

    "test":             "vitest run tests/unit",
    "test:unit":        "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch":       "vitest tests/unit",
    "test:e2e":         "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:all":         "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@hookform/resolvers":         "^5.2.2",
    "@neondatabase/serverless":    "^0.9.4",
    "@tanstack/react-query":       "^5.40.0",
    "@upstash/ratelimit":          "^2.0.1",
    "@upstash/redis":              "^1.31.6",
    "@vercel/blob":                "^0.23.4",
    "bcryptjs":                    "^2.4.3",
    "jose":                        "^5.4.1",
    "next":                        "14.2.5",
    "next-auth":                   "^5.0.0-beta.19",
    "react":                       "^18.3.1",
    "react-dom":                   "^18.3.1",
    "react-hook-form":             "^7.52.1",
    "resend":                      "^3.3.0",
    "slugify":                     "^1.6.6",
    "zod":                         "^3.23.8",
    "zustand":                     "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test":  "^1.47.0",
    "@types/bcryptjs":   "^2.4.6",
    "@types/node":       "^20.14.10",
    "@types/react":      "^18.3.3",
    "@types/react-dom":  "^18.3.0",
    "@vitest/ui":        "^2.0.0",
    "autoprefixer":      "^10.4.19",
    "jsdom":             "^25.0.0",
    "postcss":           "^8.4.39",
    "tailwindcss":       "^3.4.6",
    "tsx":               "^4.16.2",
    "typescript":        "^5.5.3",
    "vitest":            "^2.0.0"
  }
}
